import cv2
import mediapipe as mp

# Inicializar MediaPipe
mp_hands = mp.solutions.hands
mp_draw = mp.solutions.drawing_utils

hands = mp_hands.Hands(
    static_image_mode=False,
    max_num_hands=2,
    min_detection_confidence=0.5,
    min_tracking_confidence=0.5
)

# Abrir cámara
cap = cv2.VideoCapture(0)

while True:
    success, frame = cap.read()

    if not success:
        break

    # Voltear imagen para efecto espejo
    frame = cv2.flip(frame, 1)

    # Convertir a RGB
    rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)

    # Detectar manos
    results = hands.process(rgb_frame)

    if results.multi_hand_landmarks and results.multi_handedness:

        for hand_landmarks, handedness in zip(
            results.multi_hand_landmarks,
            results.multi_handedness
        ):

            label = handedness.classification[0].label

            # Colores
            if label == "Right":
                color = (0, 255, 0)  # Verde
                texto = "Derecha"
            else:
                color = (255, 0, 0)  # Azul
                texto = "Izquierda"

            # Dibujar puntos y conexiones
            mp_draw.draw_landmarks(
                frame,
                hand_landmarks,
                mp_hands.HAND_CONNECTIONS,
                mp_draw.DrawingSpec(color=color, thickness=2, circle_radius=3),
                mp_draw.DrawingSpec(color=color, thickness=2)
            )

            # Obtener posición para el texto
            h, w, c = frame.shape
            x = int(hand_landmarks.landmark[0].x * w)
            y = int(hand_landmarks.landmark[0].y * h)

            # Mostrar texto
            cv2.putText(
                frame,
                texto,
                (x, y - 20),
                cv2.FONT_HERSHEY_SIMPLEX,
                1,
                color,
                2
            )

    # Mostrar ventana
    cv2.imshow("Detector de Manos", frame)

    # Salir con ESC
    if cv2.waitKey(1) & 0xFF == 27:
        break

cap.release()
